{
  "name": "tasknotes-omnifocus",
  "version": "0.2.0",
  "description": "Obsidian plugin that bidirectionally syncs opted-in TaskNotes tasks with OmniFocus.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "tasknotes",
    "omnifocus",
    "sync"
  ],
  "author": "Nelson Love",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
